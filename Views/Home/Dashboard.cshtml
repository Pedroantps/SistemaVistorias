@{
    ViewData["Title"] = "Dashboard";
}
        <div class="dashboard-shell">
            <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-5">
                <div>
                    <h1 class="page-title">Dashboard de Vistorias</h1>
                    <p class="page-subtitle">Acompanhamento dos bens cadastrados e do andamento das vistorias.</p>
                </div>
                <div class="d-flex flex-wrap" style="gap: 15px;">
                    <button id="btnAtualizar" type="button" class="btn btn-outline-secondary" style="margin-right: 10px;" onclick="carregarDashboard()">
                        <i class="bi bi-arrow-clockwise me-2"></i>Atualizar
                    </button>
                    <button id="btnRelatorio" type="button" class="btn btn-primary" style="margin-right: 10px;" onclick="baixarRelatorioDesfazimento()">
                        <i class="bi bi-file-earmark-pdf me-2"></i>Gerar Relatório
                    </button>
                    <button type="button" class="btn btn-outline-danger" onclick="abrirModalLimpeza()">
                        <i class="bi bi-trash3 me-2"></i>Limpar Banco
                    </button>
                </div>
            </div>

            <div id="dashboardAlerta" class="alert alert-danger d-none" role="alert"></div>

            <section class="row g-3 mb-4" aria-label="Indicadores principais">
                <div class="col-md-6 col-lg-3">
                    <div class="metric-card h-100">
                        <div class="d-flex justify-content-between gap-3 mb-3">
                            <div class="metric-label">Itens cadastrados</div>
                            <div class="metric-icon metric-total"><i class="bi bi-box-seam"></i></div>
                        </div>
                        <div id="totalItens" class="metric-value">--</div>
                    </div>
                </div>
                <div class="col-md-6 col-lg-3">
                    <div class="metric-card h-100">
                        <div class="d-flex justify-content-between gap-3 mb-3">
                            <div class="metric-label">Já vistoriados</div>
                            <div class="metric-icon metric-done"><i class="bi bi-check2-circle"></i></div>
                        </div>
                        <div id="totalVistoriados" class="metric-value">--</div>
                    </div>
                </div>
                <div class="col-md-6 col-lg-3">
                    <div class="metric-card h-100">
                        <div class="d-flex justify-content-between gap-3 mb-3">
                            <div class="metric-label">Pendentes</div>
                            <div class="metric-icon metric-open"><i class="bi bi-hourglass-split"></i></div>
                        </div>
                        <div id="totalPendentes" class="metric-value">--</div>
                    </div>
                </div>
                <div class="col-md-6 col-lg-3">
                    <div class="metric-card h-100 d-flex flex-column">
                        <div class="d-flex justify-content-between gap-3 mb-3">
                            <div class="metric-label">Conclusão</div>
                            <div class="metric-icon metric-rate"><i class="bi bi-activity"></i></div>
                        </div>
                        <div id="percentualVistoriado" class="metric-value">--</div>
                        <div class="progress-track mt-auto">
                            <div id="barraConclusao" class="progress-fill"></div>
                        </div>
                    </div>
                </div>
                <div class="col-12 mt-3">
                    <div class="metric-card d-flex align-items-center justify-content-between" style="cursor: pointer; background: #fff8f1; border-color: #ffedd5; padding: 12px 18px; min-height: auto;" onclick="abrirModalAlterados()">
                        <div class="d-flex align-items-center gap-3">
                            <div class="metric-icon" style="background: #ffedd5; color: #c2410c; width: 40px; height: 40px; font-size: 1.2rem;"><i class="bi bi-exclamation-circle"></i></div>
                            <div>
                                <div class="metric-label" style="color: #c2410c; margin-bottom: 2px;">Alterados para Inservível</div>
                                <div style="font-size: 0.85rem; color: #9a3412;">Bens que tinham outra condição e foram reclassificados na vistoria.</div>
                            </div>
                        </div>
                        <div class="d-flex align-items-center gap-3">
                            <div id="totalAlterados" class="metric-value" style="color: #9a3412; font-size: 1.7rem;">--</div>
                            <i class="bi bi-chevron-right" style="color: #c2410c;"></i>
                        </div>
                    </div>
                </div>
            </section>

            <section class="row g-3 mb-4">
                <div class="col-lg-7">
                    <div class="panel h-100">
                        <h2 class="panel-title">Distribuição por contrato</h2>
                        <div id="contratosLista"></div>
                    </div>
                </div>
                <div class="col-lg-5">
                    <div class="panel h-100">
                        <h2 class="panel-title">Situação de vistoria</h2>
                        <div id="estadosLista"></div>
                    </div>
                </div>
            </section>

            <section class="panel">
                <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-3">
                    <h2 class="panel-title mb-0">Todos os bens</h2>
                    <span id="contadorTabela" class="text-muted small">--</span>
                </div>

                <div class="filters d-flex flex-column flex-md-row gap-3 mb-4">
                    <input type="search" id="buscaTabela" class="form-control mb-2 mb-md-0 flex-grow-1" placeholder="Buscar por patrimônio, descrição, contrato ou localização">
                    <select id="filtroContrato" class="form-select mb-2 mb-md-0" style="min-width: 200px;">
                        <option value="">Todos os contratos</option>
                    </select>
                    <select id="filtroStatus" class="form-select mb-2 mb-md-0" style="min-width: 180px;">
                        <option value="">Todos os status</option>
                        <option value="vistoriado">Vistoriados</option>
                        <option value="pendente">Pendentes</option>
                    </select>
                    <select id="filtroOrigem" class="form-select mb-2 mb-md-0" style="min-width: 180px;">
                        <option value="">Origem (Todas)</option>
                        <option value="avulso">Manuais (Avulsos)</option>
                        <option value="importado">Importados Planilha</option>
                    </select>
                </div>

                <div class="table-wrap">
                    <table class="table table-hover align-middle">
                        <thead>
                            <tr>
                                <th>Patrimônio AGEVAP</th>
                                <th>Contrato</th>
                                <th>Descrição</th>
                                <th>Condição</th>
                                <th>Localização</th>
                                <th>Status</th>
                                <th>Novo estado</th>
                                <th>Laudo</th>
                                <th>Data vistoria</th>
                                <th>Vistoriador</th>
                                <th>Ações</th>
                            </tr>
                        </thead>
                        <tbody id="tabelaAtivos">
                            <tr>
                                <td colspan="11" class="empty-state">Carregando dados...</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </section>
        </div> <!-- FECHAMENTO DO dashboard-shell AQUI (ANTES DOS MODAIS) -->

        <!-- Modal Limpar Banco -->
        <div class="modal fade" id="modalLimparBanco" tabindex="-1" aria-labelledby="modalLimparBancoLabel" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content" style="border-radius: 16px; border: none;">
                    <div class="modal-header" style="border-bottom: 1px solid #e7edf4;">
                        <h5 class="modal-title" id="modalLimparBancoLabel" style="font-weight: 700; color: #dc3545;">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>Atenção
                        </h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
                    </div>
                    <div class="modal-body text-center py-4">
                        <i class="bi bi-trash3" style="font-size: 3rem; color: #dc3545;"></i>
                        <p class="mt-3 mb-1" style="font-size: 1.05rem; font-weight: 600;">Tem certeza que deseja limpar todos os bens?</p>
                        <p class="text-muted small">Esta ação é irreversível. Todos os registros de bens serão removidos permanentemente do banco de dados.</p>
                    </div>
                    <div class="modal-footer justify-content-center" style="border-top: 1px solid #e7edf4;">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                        <button type="button" class="btn btn-danger" id="btnConfirmarLimpeza" onclick="limparBancoDeDados()">
                            <i class="bi bi-trash3 me-2"></i>Sim, limpar tudo
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Modal de Itens Alterados para Inservível -->
        <div class="modal fade" id="modalAlteradosInservivel" tabindex="-1" aria-labelledby="modalAlteradosLabel" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered modal-xl">
                <div class="modal-content" style="border-radius: 16px; border: none;">
                    <div class="modal-header" style="border-bottom: 1px solid #e7edf4; background: #fff8f1; border-radius: 16px 16px 0 0;">
                        <h5 class="modal-title" id="modalAlteradosLabel" style="font-weight: 700; color: #9a3412;">
                            <i class="bi bi-exclamation-circle me-2"></i>Bens Alterados para Inservível
                        </h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
                    </div>
                    <div class="modal-body p-0">
                        <div class="table-wrap" style="border: none; border-radius: 0;">
                            <table class="table table-hover align-middle mb-0">
                                <thead>
                                    <tr>
                                        <th>Patrimônio</th>
                                        <th>Contrato</th>
                                        <th>Descrição</th>
                                        <th>Condição Original</th>
                                        <th>Condição Atual</th>
                                        <th>Vistoriador</th>
                                    </tr>
                                </thead>
                                <tbody id="tabelaAlterados">
                                    <tr>
                                        <td colspan="6" class="text-center py-4 text-muted">Carregando dados...</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                    <div class="modal-footer" style="border-top: 1px solid #e7edf4;">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Fechar</button>
                    </div>
                </div>
            </div>
        </div>
@section Scripts {
    <script src="~/js/dashboard.js?v=2"></script>
    <script src="~/js/relatorios.js?v=2"></script>
    <script src="~/js/index.js?v=2"></script>
}
