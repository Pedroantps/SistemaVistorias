@{
    ViewData["Title"] = "Importação";
}
        <div class="page-shell">
            <h1 class="page-title">Importar Planilha de Patrimônio</h1>
            <p class="page-subtitle">Faça o upload do arquivo Excel oficial do controle de patrimônio.</p>

            <div class="upload-card">
                <form id="formImportacao">
                    <div class="upload-area mb-4" onclick="document.getElementById('arquivoExcel').click()">
                        <i class="bi bi-cloud-arrow-up upload-icon"></i>
                        <h5>Clique para selecionar a planilha</h5>
                        <p class="text-muted small mb-0">Formatos aceitos: .xlsx, .xlsm, .xls</p>
                        <input type="file" id="arquivoExcel" name="arquivo" class="d-none" accept=".xlsx, .xlsm, .xls" required onchange="mostrarNomeArquivo()">
                    </div>
                    
                    <div id="nomeArquivoSelecionado" class="alert alert-secondary d-none mb-4 text-center"></div>

                    <div class="d-grid">
                        <button type="submit" id="btnImportar" class="btn btn-primary btn-lg" disabled>
                            <span id="spinnerImportar" class="spinner-border spinner-border-sm d-none me-2" role="status" aria-hidden="true"></span>
                            <i class="bi bi-database-up me-2" id="iconeBotao"></i>Iniciar Importação
                        </button>
                    </div>
                </form>

                <div id="alertImportacao" class="alert d-none mt-4" role="alert"></div>
            </div>
            
            <div class="alert alert-info mt-4">
                <h6 class="alert-heading fw-bold"><i class="bi bi-info-circle me-2"></i>Regras de Importação Automática:</h6>
                <ul class="mb-0 small">
                    <li>Apenas bens com local <strong>NOVA SEDE</strong> serão importados.</li>
                    <li>Apenas bens classificados como <strong>Inservível</strong> serão importados.</li>
                    <li>O sistema lerá apenas as abas: <em>Patrimônio Adquirido</em>, <em>Patrimônio Cedido INEA GUANDU</em> e <em>Patrimônio Cedido INEA BG</em>.</li>
                </ul>
            </div>
        </div>
@section Scripts {
    <script src="~/js/importacao.js"></script>
    <script src="~/js/index.js"></script>
}