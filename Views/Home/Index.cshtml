@{
    ViewData["Title"] = "Busca de Patrimônio";
}
<div class="container py-5">
    
    <div class="welcome-header">
        <h1 class="welcome-title">Sistema de Vistorias</h1>
        <p class="lead welcome-subtitle">Identifique o bem patrimonial para iniciar o laudo técnico</p>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="search-card text-center">
                <div class="icon-box-large">
                    <i class="bi bi-qr-code-scan"></i>
                </div>
                
                <h4 class="mb-4" style="color: #344767; font-weight: 700;">Localizar Ativo</h4>
                
                <div class="mb-3 text-start">
                    <label for="contratoSelect" class="form-label" style="font-weight: 500; color: #344767;">Contrato de Gestão</label>
                    <select class="form-select form-select-lg" id="contratoGestao" required>
                        <option value="" disabled selected>Selecione o Contrato de Gestão...</option>
                        <option value="CG INEA GUANDU">CG INEA GUANDU</option>
                        <option value="CG INEA CBHs">CG INEA CBHs</option>
                        <option value="CG INEA BG">CG INEA BG</option>
                        <option value="CG INEA Nº 003/2010 - CEDIDO">CG INEA Nº 003/2010 - CEDIDO</option>
                        <option value="CG INEA Nº 002/2017 - CEDIDO">CG INEA Nº 002/2017 - CEDIDO</option>
                    </select>
                </div>

                <div class="mb-4 text-start">
                    <label for="patrimonioInput" class="form-label" style="font-weight: 500; color: #344767;">Nº do Patrimônio AGEVAP / ÓRGÃO GESTOR</label>
                    <input type="text" id="patrimonioInput" class="form-control form-control-lg" placeholder="Digite ou bipe o código...">
                </div>

                <div id="mensagemErro" class="alert alert-danger d-none" role="alert"></div>

                <button onclick="buscarAtivo()" id="btnBuscar" class="btn btn-agevap btn-lg w-100 shadow-sm">
                    <i class="bi bi-search me-2"></i> Iniciar Vistoria
                </button>
            </div>
        </div>
    </div>

</div>
@section Scripts {
    <script src="~/js/app.js?v=2"></script>
    <script src="~/js/index.js?v=2"></script>
}
