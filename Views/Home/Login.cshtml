@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - Sistema de Vistorias AGEVAP</title>
    
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" crossorigin="anonymous">
    <link rel="stylesheet" href="/css/bootstrap-icons-1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/login.css" asp-append-version="true" />
    <style>
        body {
            background-color: #f1f4f8;
            font-family: "Roboto", sans-serif;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        
        .registro-extra {
            display: none;
        }

        .registro-extra.active {
            display: block;
        }
        
        .auth-form-container {
            width: 100%;
            max-width: 400px;
        }

        #alertaLogin {
            margin-bottom: 15px;
            font-size: 13px;
            text-align: left;
        }
        
        .login-logo {
            text-align: center;
            margin-bottom: 20px;
        }
        
        .login-logo img {
            max-width: 140px;
        }
    </style>
</head>
<body>
    <div class="auth-form-container">
        <div class="auth-form">
            <div class="login-logo">
                <img src="/imgs/logo-agevap.png" alt="AGEVAP">
            </div>
            <form id="formLogin" autocomplete="on">
                <h4 id="formTitle">Entrar</h4>
                <hr />
                
                <div id="alertaLogin" class="alert d-none" role="alert" style="padding: 10px;">
                    <i class="bi bi-exclamation-circle me-2" id="alertaIcone"></i>
                    <span id="alertaTexto"></span>
                </div>

                <div class="mb-3 auth-tbox registro-extra" id="campoNomeCompleto">
                    <input type="text" id="inputNomeCompleto" class="form-control auth-tbox" placeholder="Nome completo" autocomplete="name" />
                </div>

                <div class="mb-3 auth-tbox">
                    <input type="text" id="inputUsuario" class="form-control auth-tbox" placeholder="Usuário" required autocomplete="username" />
                </div>
                
                <div class="mb-3 position-relative">
                    <input type="password" id="inputSenha" class="form-control auth-tbox pr-5" placeholder="Senha" required autocomplete="current-password" />
                    <i class="bi bi-eye toggle-password position-absolute" style="right: 10px; top: 50%; transform: translateY(-50%); cursor: pointer; font-size: 1.1rem;" id="iconeSenha" onclick="toggleSenha()"></i>
                </div>

                <div class="mb-3 position-relative registro-extra" id="campoConfirmarSenha">
                    <input type="password" id="inputConfirmarSenha" class="form-control auth-tbox" placeholder="Confirmar senha" autocomplete="new-password" />
                </div>

                <div class="mb-3">
                    <button type="submit" id="btnSubmit" class="w-100 btn btn-lg btn-primary">Entrar</button>
                </div>
                
                <div class="message mt-4">
                    <p>
                        <span id="footerTexto">Não tem conta? </span>
                        <a href="#" id="linkAlternar" onclick="alternarModo(event)">Criar conta</a>
                    </p>
                </div>
            </form>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
    <script src="/js/auth.js"></script>
    <script src="/js/login.js"></script>
    <script>
        function toggleSenha() {
            const inputSenha = document.getElementById('inputSenha');
            const icone = document.getElementById('iconeSenha');
            
            if (inputSenha.type === 'password') {
                inputSenha.type = 'text';
                icone.classList.remove('bi-eye');
                icone.classList.add('bi-eye-slash');
            } else {
                inputSenha.type = 'password';
                icone.classList.remove('bi-eye-slash');
                icone.classList.add('bi-eye');
            }
        }
        
        window.toggleSenha = toggleSenha;
    </script>
</body>
</html>
