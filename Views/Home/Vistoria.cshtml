@{
    ViewData["Title"] = "Registro de Vistoria";
}
        <div class="container py-4">
            
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 style="color: #344767; font-weight: 700;">Registro de Vistoria</h2>
                <a href="/Home/Index" class="btn btn-outline-secondary btn-sm">Voltar</a>
            </div>

            <div class="agevap-card">
                <h5 class="mb-3" style="color: #344767; font-weight: 600;"><i class="bi bi-info-circle me-2"></i>Detalhes do Ativo</h5>
                <div class="row text-muted" style="font-size: 0.9rem;">
                    <div class="col-md-6 mb-2"><strong>Patrimônio AGEVAP:</strong> <span id="lblPatrimonio">Carregando...</span></div>
                    <div class="col-md-6 mb-2"><strong>Contrato:</strong> <span id="lblContrato">Carregando...</span></div>
                </div>
            </div>

            <div class="agevap-card">
                <h5 class="mb-4" style="color: #344767; font-weight: 600;"><i class="bi bi-clipboard-check me-2"></i>Laudo Técnico</h5>
                
                <form id="formVistoria">
                    <input type="hidden" id="hiddenPatrimonio" name="patrimonioAgevap">
                    <input type="hidden" id="hiddenContrato" name="contratoGestao">
                    <input type="hidden" id="hiddenCondicao" name="condicaoFuncional">

                    <!-- Detalhes do Bem -->
                    <div class="mb-3">
                        <label class="form-label" style="font-weight: 500;">Descrição do Bem</label>
                        <input type="text" id="inputDescricao" name="descricao" class="form-control" placeholder="Ex: Cadeira de escritório" readonly>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label" style="font-weight: 500;">Patrimônio Órgão Gestor</label>
                            <input type="text" id="inputInea" name="patrimonioInea" class="form-control" placeholder="Ex: INEA-12345">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label" style="font-weight: 500;">Localização / Instalação + Endereço</label>
                            <select id="inputLocalizacao" name="instalacaoEndereco" class="form-select">
                                <option value="">Selecione a instalação...</option>
                            </select>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label" style="font-weight: 500;">Novo Estado de Conservação</label>
                        <select id="novoEstado" name="novoEstado" class="form-select" required>
                            <option value="" disabled selected>Selecione a classificação real do bem...</option>
                            <option value="OCIOSO - INSERVÍVEL">OCIOSO - INSERVÍVEL</option>
                            <option value="OBSOLETO - INSERVÍVEL">OBSOLETO - INSERVÍVEL</option>
                            <option value="RECUPERÁVEL - INSERVÍVEL">RECUPERÁVEL - INSERVÍVEL</option>
                            <option value="ANTIECONÔMICO - INSERVÍVEL">ANTIECONÔMICO - INSERVÍVEL</option>
                            <option value="IRRECUPERÁVEL - INSERVÍVEL">IRRECUPERÁVEL - INSERVÍVEL</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label" style="font-weight: 500;">Número do Laudo (Opcional)</label>
                        <input type="text" id="numeroLaudo" name="numeroLaudo" class="form-control" placeholder="Ex: LAUDO-2026-001">
                    </div>

                    <div class="mb-4">
                        <label class="form-label" style="font-weight: 500;">Fotografias do Bem</label>
                        <div class="form-text">Clique em cada quadrado para abrir a câmara ou selecionar a imagem: Esquerda, Direita, Frontal e Etiqueta.</div>
                    </div>

                    <input type="file" id="fotoEsquerda" name="fotoEsquerda" accept="image/*" capture="environment" class="d-none" required>
                    <input type="file" id="fotoDireita" name="fotoDireita" accept="image/*" capture="environment" class="d-none" required>
                    <input type="file" id="fotoFrontal" name="fotoFrontal" accept="image/*" capture="environment" class="d-none" required>
                    <input type="file" id="fotoEtiqueta" name="fotoEtiqueta" accept="image/*" capture="environment" class="d-none" required>

                    <div class="photo-grid row g-3">
                        <div class="col-12 col-sm-6">
                            <div class="photo-card">
                                <div class="photo-card-label">Foto da Esquerda</div>
                                <div class="photo-preview" id="previewEsquerda" data-input="fotoEsquerda" role="button" tabindex="0" aria-label="Abrir seletor de foto da esquerda">
                                    <div class="preview-placeholder">
                                        <i class="bi bi-camera-fill"></i>
                                        <span>Esquerda</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-12 col-sm-6">
                            <div class="photo-card">
                                <div class="photo-card-label">Foto da Direita</div>
                                <div class="photo-preview" id="previewDireita" data-input="fotoDireita" role="button" tabindex="0" aria-label="Abrir seletor de foto da direita">
                                    <div class="preview-placeholder">
                                        <i class="bi bi-camera-fill"></i>
                                        <span>Direita</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-12 col-sm-6">
                            <div class="photo-card">
                                <div class="photo-card-label">Foto Frontal</div>
                                <div class="photo-preview" id="previewFrontal" data-input="fotoFrontal" role="button" tabindex="0" aria-label="Abrir seletor de foto frontal">
                                    <div class="preview-placeholder">
                                        <i class="bi bi-camera-fill"></i>
                                        <span>Frontal</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-12 col-sm-6">
                            <div class="photo-card">
                                <div class="photo-card-label">Foto da Etiqueta</div>
                                <div class="photo-preview" id="previewEtiqueta" data-input="fotoEtiqueta" role="button" tabindex="0" aria-label="Abrir seletor de foto da etiqueta">
                                    <div class="preview-placeholder">
                                        <i class="bi bi-camera-fill"></i>
                                        <span>Etiqueta</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div id="mensagemAlerta" class="alert d-none" role="alert"></div>

                    <button type="submit" id="btnSalvar" class="btn btn-agevap w-100">
                        <i class="bi bi-cloud-arrow-up me-2"></i> Registrar Vistoria
                    </button>
                </form>
            </div>

        </div>
@section Scripts {
    <script src="~/js/vistoria.js?v=2"></script>
    <script src="~/js/index.js?v=2"></script>
}
